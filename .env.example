# ──────────────────────────────────────────────────────────────────────────
# HYPRRIDE — Environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). Never commit `.env.local`.
# ──────────────────────────────────────────────────────────────────────────

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — NEVER expose to the client. Used by Server Actions to write
# leads while Row Level Security blocks all anonymous client access.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Public site URL (used for absolute links / future webhooks).
NEXT_PUBLIC_SITE_URL="https://hyprride.com"

# ──────────────────────────────────────────────────────────────────────────
# In-house booking service (system of record).
# Used when a confirmed lead is pushed from the dashboard to the booking
# service's API. Leave blank until the integration is wired up.
# ──────────────────────────────────────────────────────────────────────────
BOOKING_SERVICE_API_URL=""
BOOKING_SERVICE_API_KEY=""
BOOKING_SERVICE_SHOP_ID=""
